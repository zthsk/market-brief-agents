# Required by SEC EDGAR. Use a real app/contact string.
SEC_USER_AGENT="Market Brief Agents MVP contact@example.com"

# Optional. Enables AI analysis, script generation, and TTS.
AI_PROVIDER="openai"
TTS_PROVIDER="openai"
OPENAI_API_KEY=""
OPENAI_TEXT_MODEL="gpt-4.1-mini"
OPENAI_TTS_MODEL="gpt-4o-mini-tts"
OPENAI_TTS_VOICE="alloy"
GEMINI_API_KEY=""
GEMINI_TEXT_MODEL="gemini-2.5-flash"
GEMINI_TTS_MODEL="gemini-2.5-flash-preview-tts"
GEMINI_TTS_VOICE="Kore"
WEB_SEARCH_PROVIDER="exa"
EXA_API_KEY=""
EXA_EXCLUDE_DOMAINS="bitrss.com,pinterest.com,medium.com,substack.com,seekingalpha.com"

# Defaults are local repo paths.
MARKET_BRIEF_DB_PATH="data/market_brief_agents.db"
MARKET_BRIEF_LOG_LEVEL="INFO"
